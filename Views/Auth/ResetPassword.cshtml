@{
    ViewData["Title"] = "Đặt Lại Mật Khẩu";
}

<div class="auth-container glass-panel animate-fade-in" style="max-width: 480px; margin: 80px auto;">
    <h3 class="text-center fw-bold mb-2 poppins-title">
        Đặt Lại Mật Khẩu
    </h3>
    <p class="text-center text-secondary small mb-4">
        Vui lòng tạo mật khẩu mới cho tài khoản <strong class="text-dark">@ViewBag.Email</strong>
    </p>

    <form asp-controller="Auth" asp-action="ResetPassword" method="post">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success small py-2 mb-3">@TempData["SuccessMessage"]</div>
        }
        
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <input type="hidden" name="email" value="@ViewBag.Email" />

        <div class="mb-3">
            <label class="form-label text-secondary small fw-bold">Mã xác nhận (OTP)</label>
            <input type="text" name="otp" class="form-control form-premium-control" placeholder="123456" required />
            <div class="form-text small">Kiểm tra hộp thư email của bạn để lấy mã OTP 6 số.</div>
        </div>

        <div class="mb-3">
            <label class="form-label text-secondary small fw-bold">Mật khẩu mới</label>
            <input type="password" name="newPassword" class="form-control form-premium-control" placeholder="••••••••" required />
        </div>

        <div class="mb-4">
            <label class="form-label text-secondary small fw-bold">Nhập lại mật khẩu mới</label>
            <input type="password" name="confirmPassword" class="form-control form-premium-control" placeholder="••••••••" required />
        </div>

        <button type="submit" class="btn btn-premium w-100 py-3 fw-bold mb-3">Cập Nhật Mật Khẩu</button>
        
        <p class="text-center small text-secondary">
            Nhớ mật khẩu? <a asp-action="Login" class="text-info text-decoration-none fw-bold">Đăng nhập</a>
        </p>
    </form>
</div>
