@{
    ViewData["Title"] = "Đăng Nhập";
}

<div class="auth-container glass-panel animate-fade-in" style="max-width: 480px; margin: 80px auto;">
    <h3 class="text-center fw-bold mb-4 poppins-title">
        Đăng Nhập
    </h3>

    <form asp-controller="Auth" asp-action="Login" method="post" id="loginForm">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success small py-2 mb-3">@TempData["SuccessMessage"]</div>
        }
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="mb-3">
            <label class="form-label text-secondary small fw-bold">Email đăng nhập</label>
            <input type="email" name="email" id="emailInput" class="form-control form-premium-control" placeholder="example@domain.com" required />
        </div>

        <div class="mb-4">
            <label class="form-label text-secondary small fw-bold">Mật khẩu</label>
            <input type="password" name="password" id="passwordInput" class="form-control form-premium-control" placeholder="••••••••" value="123456" required />
            <div class="text-end mt-2">
                <a asp-action="ForgotPassword" class="text-info small text-decoration-none fw-bold">Quên mật khẩu?</a>
            </div>
        </div>

        <button type="submit" class="btn btn-premium w-100 py-3 fw-bold mb-3">Đăng Nhập</button>
        
        <div class="position-relative mt-3 mb-4">
            <hr class="text-muted" />
            <span class="position-absolute top-50 start-50 translate-middle bg-white px-2 text-muted small fw-bold">HOẶC</span>
        </div>

        <a asp-action="LoginWithGoogle" class="btn btn-outline-dark w-100 py-2 mb-3 fw-bold d-flex align-items-center justify-content-center" style="border-radius: 12px; gap: 10px;">
            <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" style="width: 20px;" />
            Tiếp tục với Google
        </a>
        
        <p class="text-center small text-secondary">
            Chưa có tài khoản? <a asp-action="Register" class="text-info text-decoration-none fw-bold">Đăng ký ngay</a>
        </p>
    </form>
</div>
