@{
    ViewData["Title"] = "Từ Chối Truy Cập";
}

<div class="auth-container glass-panel text-center">
    <i class="fa-solid fa-triangle-exclamation text-danger display-1 mb-4"></i>
    <h3 class="fw-bold text-danger mb-3">Từ Chối Truy Cập</h3>
    <p class="text-secondary mb-4">Tài khoản của bạn không có quyền truy cập vào chức năng hoặc trang này. Vui lòng chuyển đổi tài khoản hoặc liên hệ Admin.</p>
    <div class="d-flex justify-content-center gap-3">
        <a class="btn btn-premium" asp-controller="Home" asp-action="Index">Về Trang Chủ</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="btn btn-outline-warning" asp-controller="Auth" asp-action="ChooseRole">Đổi vai trò</a>
        }
    </div>
</div>
