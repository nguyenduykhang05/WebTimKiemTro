@{
    ViewData["Title"] = "Quên Mật Khẩu";
}

<div class="auth-container glass-panel animate-fade-in" style="max-width: 480px; margin: 80px auto;">
    <h3 class="text-center fw-bold mb-2 poppins-title">
        Quên Mật Khẩu
    </h3>
    <p class="text-center text-secondary small mb-4">
        Nhập email tài khoản của bạn để nhận liên kết khôi phục mật khẩu.
    </p>

    <form asp-controller="Auth" asp-action="ForgotPassword" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="mb-4">
            <label class="form-label text-secondary small fw-bold">Email đăng ký</label>
            <input type="email" name="email" class="form-control form-premium-control" placeholder="example@domain.com" required />
        </div>

        <button type="submit" class="btn btn-premium w-100 py-3 fw-bold mb-3">Gửi Liên Kết Khôi Phục</button>
        
        <p class="text-center small text-secondary">
            Nhớ mật khẩu? <a asp-action="Login" class="text-info text-decoration-none fw-bold">Đăng nhập</a>
        </p>
    </form>
</div>
