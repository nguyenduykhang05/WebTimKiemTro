@model SmartRoomFinder.Models.UserModel

@{
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
}

<div class="row mt-4 mb-5">
    <div class="col-lg-6 mx-auto">
        <div class="glass-panel p-5 text-center position-relative overflow-hidden">
            <!-- Glow background effect -->
            <div class="position-absolute" style="background: radial-gradient(circle, rgba(99,102,241,0.2) 0%, rgba(0,0,0,0) 70%); width: 300px; height: 300px; top: -50px; left: calc(50% - 150px); pointer-events: none; z-index: 0;"></div>

            <div class="position-relative" style="z-index: 1;">
                <img src="@Model.ProfileImageUrl" class="rounded-circle border border-secondary border-3 mb-4 shadow" style="width: 120px; height: 120px; object-fit: cover;" alt="Avatar" onerror="this.src='https://i.pravatar.cc/120?u=@Model.Email'">
                
                <h3 class="fw-bold mb-1">@Model.Name</h3>
                <span class="badge bg-indigo px-3 py-2 fs-7 mb-4">Vai trò: @Model.Role.ToString().ToUpper()</span>

                <div class="text-start mx-auto mt-2" style="max-width: 400px;">
                    <div class="mb-3 d-flex align-items-center text-secondary">
                        <i class="fa-solid fa-envelope text-info me-3 fs-5" style="width: 24px;"></i>
                        <div>
                            <span class="small text-muted d-block" style="font-size: 0.75rem;">Email tài khoản</span>
                            <span class="text-white">@Model.Email</span>
                        </div>
                    </div>

                    <div class="mb-3 d-flex align-items-center text-secondary">
                        <i class="fa-solid fa-phone text-info me-3 fs-5" style="width: 24px;"></i>
                        <div>
                            <span class="small text-muted d-block" style="font-size: 0.75rem;">Số điện thoại</span>
                            <span class="text-white">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Chưa cập nhật" : Model.PhoneNumber)</span>
                        </div>
                    </div>

                    <div class="mb-3 d-flex align-items-center text-secondary">
                        <i class="fa-solid fa-location-dot text-info me-3 fs-5" style="width: 24px;"></i>
                        <div>
                            <span class="small text-muted d-block" style="font-size: 0.75rem;">Địa điểm</span>
                            <span class="text-white">@Model.Location</span>
                        </div>
                    </div>

                    <div class="mb-4 d-flex align-items-center text-secondary">
                        <i class="fa-regular fa-calendar-days text-info me-3 fs-5" style="width: 24px;"></i>
                        <div>
                            <span class="small text-muted d-block" style="font-size: 0.75rem;">Ngày tham gia</span>
                            <span class="text-white">@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-3 justify-content-center mt-4">
                    <a class="btn btn-premium-secondary px-4" asp-controller="Home" asp-action="Index">Về Trang Chủ</a>
                    <a class="btn btn-premium px-4" asp-action="Edit"><i class="fa-solid fa-user-pen me-2"></i>Chỉnh sửa hồ sơ</a>
                </div>
            </div>
        </div>
    </div>
</div>
