@model SmartRoomFinder.Models.KycProfileModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Xác Thực Danh Tính (KYC)";
    var existing = ViewBag.ExistingKyc as SmartRoomFinder.Models.KycProfileModel;
    var reason = ViewBag.Reason as string;
}

<div class="container py-5" style="max-width: 780px;">
    @if (reason == "required")
    {
        <div class="alert alert-warning rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            <strong>Bắt buộc xác thực danh tính!</strong> Bạn cần hoàn tất KYC trước khi có thể đăng tin phòng trọ. Điều này giúp bảo vệ người thuê khỏi lừa đảo.
        </div>
    }

    @if (existing?.Status == SmartRoomFinder.Models.KycStatus.Rejected)
    {
        <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="fa-solid fa-circle-xmark me-2"></i>
            <strong>Hồ sơ bị từ chối!</strong> Lý do: <em>@existing.RejectReason</em>
            <br /><small class="text-muted">Vui lòng kiểm tra lại ảnh CCCD và nộp lại bên dưới.</small>
        </div>
    }

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header py-4 px-4" style="background: linear-gradient(135deg, #1e3a5f, #2563eb);">
            <h4 class="text-white fw-bold mb-1">
                <i class="fa-solid fa-id-card me-2"></i> Xác Thực Danh Tính (eKYC)
            </h4>
            <p class="text-white-50 mb-0 small">Hệ thống sẽ tự động phân tích CCCD bằng AI và gửi Admin xét duyệt trong 24h.</p>
        </div>
        <div class="card-body p-4">
            <form asp-action="SubmitKyc" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <!-- Số CCCD -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Số CCCD <span class="text-danger">*</span></label>
                    <input type="text" name="identityCardNumber" class="form-control form-control-lg rounded-3"
                           placeholder="Nhập 12 chữ số CCCD" pattern="\d{9,12}" maxlength="12"
                           value="@existing?.IdentityCardNumber" required />
                    <div class="form-text">Số định danh cá nhân 12 chữ số trên thẻ CCCD/CMND.</div>
                </div>

                <div class="row g-3 mb-4">
                    <!-- Ảnh mặt trước -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Ảnh mặt trước CCCD <span class="text-danger">*</span></label>
                        <div class="upload-box rounded-3 border border-2 border-dashed text-center p-3 position-relative" style="min-height:160px; cursor:pointer;"
                             onclick="document.getElementById('frontImage').click()">
                            <img id="frontPreview" src="@(existing?.FrontImageUrl ?? "")" class="img-fluid rounded-2 mb-2 @(string.IsNullOrEmpty(existing?.FrontImageUrl) ? "d-none" : "")" style="max-height:120px;" />
                            <div id="frontPlaceholder" class="@(!string.IsNullOrEmpty(existing?.FrontImageUrl) ? "d-none" : "")">
                                <i class="fa-solid fa-camera fa-2x text-muted mb-2"></i>
                                <p class="text-muted small mb-0">Bấm để chọn ảnh</p>
                            </div>
                            <input type="file" id="frontImage" name="frontImage" accept="image/*" class="d-none"
                                   onchange="previewImage(this,'frontPreview','frontPlaceholder')" @(existing?.Status != SmartRoomFinder.Models.KycStatus.Approved ? "required" : "") />
                        </div>
                    </div>
                    <!-- Ảnh mặt sau -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Ảnh mặt sau CCCD <span class="text-danger">*</span></label>
                        <div class="upload-box rounded-3 border border-2 border-dashed text-center p-3 position-relative" style="min-height:160px; cursor:pointer;"
                             onclick="document.getElementById('backImage').click()">
                            <img id="backPreview" src="@(existing?.BackImageUrl ?? "")" class="img-fluid rounded-2 mb-2 @(string.IsNullOrEmpty(existing?.BackImageUrl) ? "d-none" : "")" style="max-height:120px;" />
                            <div id="backPlaceholder" class="@(!string.IsNullOrEmpty(existing?.BackImageUrl) ? "d-none" : "")">
                                <i class="fa-solid fa-camera fa-2x text-muted mb-2"></i>
                                <p class="text-muted small mb-0">Bấm để chọn ảnh</p>
                            </div>
                            <input type="file" id="backImage" name="backImage" accept="image/*" class="d-none"
                                   onchange="previewImage(this,'backPreview','backPlaceholder')" @(existing?.Status != SmartRoomFinder.Models.KycStatus.Approved ? "required" : "") />
                        </div>
                    </div>
                </div>

                <!-- Ảnh Selfie -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Ảnh Selfie cầm CCCD sát mặt <span class="text-danger">*</span></label>
                    <div class="alert alert-info rounded-3 small py-2 mb-2">
                        <i class="fa-solid fa-circle-info me-1"></i>
                        Chụp ảnh khuôn mặt rõ ràng, cầm thẻ CCCD đặt sát mặt. AI sẽ so khớp khuôn mặt để chống mạo danh.
                    </div>
                    <div class="upload-box rounded-3 border border-2 border-dashed text-center p-3 position-relative" style="min-height:160px; cursor:pointer;"
                         onclick="document.getElementById('selfieImage').click()">
                        <img id="selfiePreview" src="@(existing?.SelfieImageUrl ?? "")" class="img-fluid rounded-2 mb-2 @(string.IsNullOrEmpty(existing?.SelfieImageUrl) ? "d-none" : "")" style="max-height:140px;" />
                        <div id="selfiePlaceholder" class="@(!string.IsNullOrEmpty(existing?.SelfieImageUrl) ? "d-none" : "")">
                            <i class="fa-solid fa-person fa-2x text-muted mb-2"></i>
                            <p class="text-muted small mb-0">Bấm để chọn ảnh selfie</p>
                        </div>
                        <input type="file" id="selfieImage" name="selfieImage" accept="image/*" class="d-none"
                               onchange="previewImage(this,'selfiePreview','selfiePlaceholder')" @(existing?.Status != SmartRoomFinder.Models.KycStatus.Approved ? "required" : "") />
                    </div>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg py-3 fw-bold rounded-3">
                        <i class="fa-solid fa-paper-plane me-2"></i>
                        @(existing != null ? "Nộp lại hồ sơ KYC" : "Gửi hồ sơ xác thực")
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Cam kết bảo mật -->
    <div class="mt-4 p-3 rounded-3 small text-muted text-center" style="background: rgba(255,255,255,0.05);">
        <i class="fa-solid fa-shield-halved me-1 text-success"></i>
        Thông tin CCCD của bạn được mã hóa và chỉ dùng để xác thực danh tính. Chúng tôi không lưu trữ hay chia sẻ với bên thứ ba.
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(input, previewId, placeholderId) {
            const preview = document.getElementById(previewId);
            const placeholder = document.getElementById(placeholderId);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');
                    placeholder.classList.add('d-none');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
