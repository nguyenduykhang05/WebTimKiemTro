@model IEnumerable<SmartRoomFinder.Models.KycProfileModel>
@using SmartRoomFinder.Models
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Xét Duyệt Hồ Sơ";
    var filter = ViewBag.Filter as string ?? "all";
    int pendingCount = ViewBag.PendingCount ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="fa-solid fa-id-card-clip me-2 text-primary"></i> Xét Duyệt Hồ Sơ</h4>
        <p class="text-muted small mb-0">Xác thực danh tính Chủ trọ bằng CCCD và AI Face Matching.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="VerifyKyc" asp-route-filter="pending" class="btn btn-sm @(filter=="pending" ? "btn-warning" : "btn-outline-warning") rounded-3 fw-bold">
            <i class="fa-solid fa-clock me-1"></i> Chờ duyệt <span class="badge bg-dark ms-1">@pendingCount</span>
        </a>
        <a asp-action="VerifyKyc" asp-route-filter="all" class="btn btn-sm @(filter=="all" ? "btn-secondary" : "btn-outline-secondary") rounded-3">Tất cả</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success rounded-3 border-0 mb-4">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger rounded-3 border-0 mb-4">@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm rounded-4 p-5 text-center">
        <i class="fa-solid fa-check-double fa-3x text-success mb-3"></i>
        <h5 class="fw-bold">Không có hồ sơ nào cần xét duyệt</h5>
        <p class="text-muted small">Tất cả hồ sơ KYC đã được xử lý xong.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var kyc in Model)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header py-3 px-4 d-flex justify-content-between align-items-center"
                         style="background: @(kyc.Status == KycStatus.Pending ? "rgba(245,158,11,0.1)" : kyc.Status == KycStatus.Approved ? "rgba(16,185,129,0.1)" : "rgba(220,38,38,0.1)");">
                        <div class="d-flex align-items-center gap-3">
                            <img src="@kyc.User?.ProfileImageUrl" class="rounded-circle" style="width:40px;height:40px;object-fit:cover;" />
                            <div>
                                <span class="fw-bold">@kyc.User?.Name</span>
                                <span class="text-muted small ms-2">@kyc.User?.Email</span>
                                <br /><span class="small text-muted">Nộp lúc: @kyc.SubmittedAt.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</span>
                            </div>
                        </div>
                        <span class="badge rounded-pill fs-6
                              @(kyc.Status == KycStatus.Pending ? "bg-warning text-dark" :
                                kyc.Status == KycStatus.Approved ? "bg-success" : "bg-danger")">
                            @(kyc.Status == KycStatus.Pending ? "⏳ Chờ duyệt" :
                              kyc.Status == KycStatus.Approved ? "✅ Đã duyệt" : "❌ Từ chối")
                        </span>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-4">
                            <!-- Thông tin OCR -->
                            <div class="col-md-4">
                                <h6 class="fw-bold text-primary mb-3"><i class="fa-solid fa-robot me-1"></i> Kết quả AI OCR</h6>
                                <table class="table table-sm table-borderless small mb-0">
                                    <tr><td class="text-muted fw-bold">Số CCCD</td><td class="font-monospace fw-bold">@kyc.IdentityCardNumber</td></tr>
                                    <tr><td class="text-muted fw-bold">Họ tên</td><td>@(string.IsNullOrEmpty(kyc.FullNameOnCard) ? "<span class='text-muted'>Chưa đọc được</span>" : kyc.FullNameOnCard)</td></tr>
                                    <tr><td class="text-muted fw-bold">Ngày sinh</td><td>@(string.IsNullOrEmpty(kyc.DateOfBirthOnCard) ? "<span class='text-muted'>—</span>" : kyc.DateOfBirthOnCard)</td></tr>
                                </table>

                                @if (kyc.AiFaceMatchScore.HasValue)
                                {
                                    <div class="mt-3 p-3 rounded-3" style="background:rgba(37,99,235,0.08);">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span class="small fw-bold">Face Match Score</span>
                                            <span class="badge @(kyc.AiIsMatch == true ? "bg-success" : "bg-danger")">
                                                @(kyc.AiIsMatch == true ? "✅ Khớp" : "❌ Không khớp")
                                            </span>
                                        </div>
                                        <div class="progress mb-1" style="height:10px;">
                                            <div class="progress-bar @(kyc.AiFaceMatchScore >= 0.7 ? "bg-success" : "bg-danger")"
                                                 style="width:@((int)(kyc.AiFaceMatchScore.Value * 100))%"></div>
                                        </div>
                                        <div class="small text-center fw-bold">@((int)(kyc.AiFaceMatchScore.Value * 100))%</div>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-secondary py-2 small mt-3 mb-0 rounded-3">
                                        <i class="fa-solid fa-circle-info me-1"></i> AI chưa xử lý được ảnh này.
                                    </div>
                                }
                            </div>

                            <!-- Ảnh CCCD & Selfie -->
                            <div class="col-md-8">
                                <h6 class="fw-bold mb-3"><i class="fa-solid fa-images me-1"></i> Ảnh xác thực</h6>
                                <div class="row g-2">
                                    <div class="col-4">
                                        <p class="small text-muted fw-bold mb-1">Mặt trước CCCD</p>
                                        <a href="@kyc.FrontImageUrl" target="_blank">
                                            <img src="@kyc.FrontImageUrl" class="img-fluid rounded-3 border" style="max-height:120px;width:100%;object-fit:cover;" />
                                        </a>
                                    </div>
                                    <div class="col-4">
                                        <p class="small text-muted fw-bold mb-1">Mặt sau CCCD</p>
                                        <a href="@kyc.BackImageUrl" target="_blank">
                                            <img src="@kyc.BackImageUrl" class="img-fluid rounded-3 border" style="max-height:120px;width:100%;object-fit:cover;" />
                                        </a>
                                    </div>
                                    <div class="col-4">
                                        <p class="small text-muted fw-bold mb-1">Selfie cầm CCCD</p>
                                        <a href="@kyc.SelfieImageUrl" target="_blank">
                                            <img src="@kyc.SelfieImageUrl" class="img-fluid rounded-3 border" style="max-height:120px;width:100%;object-fit:cover;" />
                                        </a>
                                    </div>
                                </div>

                                @if (kyc.Status == KycStatus.Pending)
                                {
                                    <div class="d-flex gap-2 mt-3">
                                        <!-- Duyệt -->
                                        <form asp-action="ApproveKyc" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@kyc.Id" />
                                            <button type="submit" class="btn btn-success px-4 rounded-3 fw-bold"
                                                    onclick="return confirm('Xác nhận phê duyệt hồ sơ KYC của @kyc.User?.Name?')">
                                                <i class="fa-solid fa-check me-1"></i> Phê duyệt
                                            </button>
                                        </form>
                                        <!-- Từ chối -->
                                        <button class="btn btn-danger px-4 rounded-3 fw-bold"
                                                data-bs-toggle="modal" data-bs-target="#rejectModal_@kyc.Id">
                                            <i class="fa-solid fa-xmark me-1"></i> Từ chối
                                        </button>
                                    </div>
                                }
                                else if (kyc.Status == KycStatus.Rejected)
                                {
                                    <div class="alert alert-danger rounded-3 border-0 small mt-3 mb-0 py-2">
                                        <strong>Lý do từ chối:</strong> @kyc.RejectReason
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal từ chối -->
            <div class="modal fade" id="rejectModal_@kyc.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content rounded-4 border-0 shadow-lg">
                        <div class="modal-header border-0 pb-0">
                            <h5 class="modal-title fw-bold text-danger"><i class="fa-solid fa-triangle-exclamation me-2"></i> Từ chối hồ sơ KYC</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <form asp-action="RejectKyc" method="post">
                            @Html.AntiForgeryToken()
                            <div class="modal-body pt-2">
                                <input type="hidden" name="id" value="@kyc.Id" />
                                <p class="text-muted small mb-3">Lý do sẽ được hiển thị cho <strong>@kyc.User?.Name</strong> để họ sửa và nộp lại.</p>
                                <textarea name="rejectReason" class="form-control rounded-3" rows="3"
                                          placeholder="Ví dụ: Ảnh CCCD mờ, không đọc được số. Vui lòng chụp lại trong điều kiện ánh sáng tốt hơn."
                                          required></textarea>
                            </div>
                            <div class="modal-footer border-0 pt-0">
                                <button type="button" class="btn btn-outline-secondary rounded-3" data-bs-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-danger px-4 rounded-3 fw-bold">Xác nhận từ chối</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
