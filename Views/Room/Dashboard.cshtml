@model SmartRoomFinder.Models.ViewModels.LandlordStatsViewModel

@{
    ViewData["Title"] = "Dashboard Chủ Trọ";
    var recentApps = ViewBag.RecentApplications as IEnumerable<SmartRoomFinder.Models.ApplicationModel>;
}

<div class="d-flex justify-content-between align-items-center mt-3 mb-4">
    <div>
        <h3 class="fw-bold m-0" style="background: var(--gradient-primary); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            <i class="fa-solid fa-chart-pie me-2"></i>Tổng Quan Quản Lý
        </h3>
        <p class="text-secondary mt-1 mb-0">Theo dõi hiệu quả kinh doanh và số lượng phòng của bạn.</p>
    </div>
    <a class="btn btn-premium px-4" asp-action="Create"><i class="fa-solid fa-plus me-2"></i>Đăng tin mới</a>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="glass-panel p-4 h-100 position-relative overflow-hidden">
            <div class="position-absolute top-0 end-0 p-3 opacity-25">
                <i class="fa-solid fa-house-chimney fa-4x text-primary"></i>
            </div>
            <div class="text-secondary fw-bold small text-uppercase mb-2">Tổng số phòng</div>
            <h2 class="fw-bold mb-0 text-primary">@Model.TotalRooms</h2>
            <div class="mt-2 small text-secondary">
                <span class="text-warning fw-bold"><i class="fa-solid fa-clock me-1"></i>@Model.PendingRooms</span> phòng đang chờ duyệt
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="glass-panel p-4 h-100 position-relative overflow-hidden">
            <div class="position-absolute top-0 end-0 p-3 opacity-25">
                <i class="fa-solid fa-eye fa-4x text-info"></i>
            </div>
            <div class="text-secondary fw-bold small text-uppercase mb-2">Lượt xem (Views)</div>
            <h2 class="fw-bold mb-0 text-info">@Model.TotalViews</h2>
            <div class="mt-2 small text-secondary">Tổng lượt xem các bài đăng</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="glass-panel p-4 h-100 position-relative overflow-hidden">
            <div class="position-absolute top-0 end-0 p-3 opacity-25">
                <i class="fa-solid fa-phone-volume fa-4x text-success"></i>
            </div>
            <div class="text-secondary fw-bold small text-uppercase mb-2">Lượt lấy sđt</div>
            <h2 class="fw-bold mb-0 text-success">@Model.TotalContacts</h2>
            <div class="mt-2 small text-secondary">Khách đã nhấn xem số điện thoại</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="glass-panel p-4 h-100 position-relative overflow-hidden" style="border: 1px solid rgba(245, 158, 11, 0.3);">
            <div class="position-absolute top-0 end-0 p-3 opacity-25">
                <i class="fa-solid fa-envelope-open-text fa-4x text-warning"></i>
            </div>
            <div class="text-warning fw-bold small text-uppercase mb-2">Đơn thuê chờ duyệt</div>
            <h2 class="fw-bold mb-0 text-warning">@Model.PendingApplications</h2>
            <div class="mt-2 small">
                <a asp-action="Applications" class="text-warning text-decoration-none fw-bold">Xem danh sách <i class="fa-solid fa-arrow-right ms-1"></i></a>
            </div>
        </div>
    </div>
</div>

<!-- Recent Applications & Quick Actions -->
<div class="row g-4 mb-5">
    <!-- Recent Applications -->
    <div class="col-lg-8">
        <div class="card border border-secondary border-opacity-10 shadow-sm h-100" style="border-radius: 1.2rem; overflow: hidden;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                    <h5 class="fw-bold m-0"><i class="fa-solid fa-bell text-warning me-2"></i>Đơn Đăng Ký Mới Nhất</h5>
                    <a asp-action="Applications" class="btn btn-sm btn-light border shadow-sm rounded-pill px-3">Xem tất cả</a>
                </div>

                @if (recentApps == null || !recentApps.Any())
                {
                    <div class="text-center py-5 text-secondary">
                        <i class="fa-regular fa-folder-open fs-1 text-secondary opacity-50 mb-3"></i>
                        <h6 class="fw-bold text-secondary">Chưa có đơn đăng ký nào gần đây.</h6>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 text-nowrap">
                            <thead class="table-light">
                                <tr>
                                    <th class="py-3 px-4 border-bottom text-uppercase text-secondary" style="font-size: 0.7rem; letter-spacing: 0.5px;">Phòng</th>
                                    <th class="py-3 border-bottom text-uppercase text-secondary" style="font-size: 0.7rem; letter-spacing: 0.5px;">Người gửi</th>
                                    <th class="py-3 border-bottom text-uppercase text-secondary" style="font-size: 0.7rem; letter-spacing: 0.5px;">Ngày gửi</th>
                                    <th class="py-3 border-bottom text-uppercase text-secondary text-center" style="font-size: 0.7rem; letter-spacing: 0.5px;">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody class="border-top-0">
                                @foreach (var app in recentApps)
                                {
                                    <tr>
                                        <td class="px-4 py-3">
                                            <div class="fw-bold text-truncate text-dark" style="max-width: 250px; font-size: 0.95rem;">@app.RoomTitle</div>
                                        </td>
                                        <td><span class="text-secondary fw-medium">@app.RenterName</span></td>
                                        <td><span class="text-secondary"><i class="fa-regular fa-calendar me-1"></i>@app.CreatedAt.ToString("dd/MM/yyyy")</span></td>
                                        <td class="text-center">
                                            <span class="badge rounded-pill px-3 py-2 fw-bold shadow-sm @(app.Status switch {
                                                "approved" => "bg-success bg-opacity-10 text-success border border-success border-opacity-25",
                                                "rejected" => "bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25",
                                                _ => "bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25"
                                            })">
                                                @(app.Status switch {
                                                    "approved" => "Được nhận",
                                                    "rejected" => "Từ chối",
                                                    _ => "Đang chờ"
                                                })
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="col-lg-4">
        <div class="card border border-secondary border-opacity-10 shadow-sm h-100" style="border-radius: 1.2rem; overflow: hidden;">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4 border-bottom pb-3"><i class="fa-solid fa-bolt text-info me-2"></i>Lối Tắt (Quick Links)</h5>
                
                <div class="d-grid gap-3">
                    <a asp-action="Manage" class="btn btn-light border text-start py-3 px-3 d-flex align-items-center shadow-sm" style="border-radius: 1rem; transition: all 0.2s;">
                        <div class="bg-info bg-opacity-10 rounded-circle me-3 text-info d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; flex-shrink: 0;"><i class="fa-solid fa-list-check fs-5"></i></div>
                        <div>
                            <div class="fw-bold text-dark mb-1">Quản lý phòng</div>
                            <div class="small text-secondary" style="font-size: 0.75rem;">Xem, sửa, xóa các phòng đang cho thuê</div>
                        </div>
                    </a>
                    <a asp-action="Applications" class="btn btn-light border text-start py-3 px-3 d-flex align-items-center shadow-sm" style="border-radius: 1rem; transition: all 0.2s;">
                        <div class="bg-warning bg-opacity-10 rounded-circle me-3 text-warning d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; flex-shrink: 0;"><i class="fa-solid fa-file-signature fs-5"></i></div>
                        <div>
                            <div class="fw-bold text-dark mb-1">Duyệt đơn ứng tuyển</div>
                            <div class="small text-secondary" style="font-size: 0.75rem;">Quản lý các yêu cầu thuê từ khách</div>
                        </div>
                    </a>
                    <a asp-controller="Profile" asp-action="Index" class="btn btn-light border text-start py-3 px-3 d-flex align-items-center shadow-sm" style="border-radius: 1rem; transition: all 0.2s;">
                        <div class="bg-success bg-opacity-10 rounded-circle me-3 text-success d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; flex-shrink: 0;"><i class="fa-solid fa-user-pen fs-5"></i></div>
                        <div>
                            <div class="fw-bold text-dark mb-1">Hồ sơ của bạn</div>
                            <div class="small text-secondary" style="font-size: 0.75rem;">Cập nhật thông tin cá nhân và SĐT</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
