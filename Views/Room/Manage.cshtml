@model IEnumerable<SmartRoomFinder.Models.RoomModel>

@{
    ViewData["Title"] = "Quản Lý Phòng Trọ Của Bạn";
}

<div class="d-flex justify-content-between align-items-center mt-3 mb-4">
    <h3 class="fw-bold"><i class="fa-solid fa-hotel text-info me-2"></i>Phòng Trọ Bạn Đã Đăng</h3>
    <div>
        <a class="btn btn-warning text-dark fw-bold me-2" asp-controller="ServicePricing" asp-action="Index"><i class="fa-solid fa-crown me-1"></i> Nâng cấp tài khoản</a>
        <a class="btn btn-premium" asp-action="Create"><i class="fa-solid fa-plus me-1"></i> Đăng phòng mới</a>
    </div>
</div>

<div class="card border border-secondary border-opacity-10 shadow-sm mb-5" style="border-radius: 1.2rem; overflow: hidden;">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fa-solid fa-house-circle-exclamation fs-1 text-secondary mb-3"></i>
            <h5 class="text-secondary">Bạn chưa đăng tin phòng trọ nào.</h5>
            <a class="btn btn-premium mt-3" asp-action="Create">Đăng tin ngay</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-nowrap">
                <thead class="table-light">
                    <tr>
                        <th class="py-3 px-4 border-bottom text-uppercase text-secondary" style="font-size: 0.7rem; letter-spacing: 0.5px;">Hình ảnh</th>
                        <th class="py-3 border-bottom text-uppercase text-secondary" style="font-size: 0.7rem; letter-spacing: 0.5px;">Tiêu đề phòng</th>
                        <th class="py-3 border-bottom text-uppercase text-secondary" style="font-size: 0.7rem; letter-spacing: 0.5px;">Khu vực</th>
                        <th class="py-3 border-bottom text-uppercase text-secondary" style="font-size: 0.7rem; letter-spacing: 0.5px;">Giá thuê</th>
                        <th class="py-3 border-bottom text-uppercase text-secondary" style="font-size: 0.7rem; letter-spacing: 0.5px;">Lượt xem</th>
                        <th class="py-3 border-bottom text-uppercase text-secondary" style="font-size: 0.7rem; letter-spacing: 0.5px;">Trạng thái duyệt</th>
                        <th class="py-3 border-bottom text-uppercase text-secondary" style="font-size: 0.7rem; letter-spacing: 0.5px;">Gói dịch vụ</th>
                        <th class="py-3 px-4 border-bottom text-uppercase text-secondary text-center" style="font-size: 0.7rem; letter-spacing: 0.5px;">Hành động</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var room in Model)
                    {
                        <tr>
                            <td class="px-4 py-3">
                                <img src="@room.MainImageUrl" class="rounded-3 shadow-sm border" style="width: 80px; height: 55px; object-fit: cover;" alt="Cover" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=80&q=80'">
                            </td>
                            <td>
                                <div class="fw-bold text-truncate text-dark" style="max-width: 220px; font-size: 0.95rem;">@room.Title</div>
                                <span class="badge bg-light text-secondary border mt-1 fw-normal">@room.Type.ToString() • @room.Area m²</span>
                            </td>
                            <td><span class="text-secondary fw-medium"><i class="fa-solid fa-location-dot text-danger me-1"></i>@room.Location</span></td>
                            <td><span class="text-primary fw-bold" style="font-size: 0.95rem;">@room.Price.ToString("#,##0") đ</span></td>
                            <td>
                                <div class="d-flex align-items-center text-secondary">
                                    <i class="fa-solid fa-eye me-2"></i> <span class="fw-bold text-dark">@room.ViewCount</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge rounded-pill px-3 py-2 fw-bold shadow-sm @(room.ApprovalStatus switch {
                                    SmartRoomFinder.Models.RoomStatus.Verified => "bg-success bg-opacity-10 text-success border border-success border-opacity-25",
                                    SmartRoomFinder.Models.RoomStatus.Pending => "bg-info bg-opacity-10 text-info border border-info border-opacity-25",
                                    SmartRoomFinder.Models.RoomStatus.NeedsInfo => "bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25",
                                    _ => "bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25"
                                })">
                                    <i class="fa-solid @(room.ApprovalStatus == SmartRoomFinder.Models.RoomStatus.Verified ? "fa-check-circle" : room.ApprovalStatus == SmartRoomFinder.Models.RoomStatus.Pending ? "fa-clock" : "fa-circle-exclamation") me-1"></i>
                                    @room.ApprovalStatus.ToString()
                                </span>
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <div class="fw-bold mb-1 @(room.Package == SmartRoomFinder.Models.RoomPackage.VipNoiBat ? "text-danger" : room.Package == SmartRoomFinder.Models.RoomPackage.Default ? "text-secondary" : "text-primary")">
                                        <i class="fa-solid fa-crown"></i> @room.Package.ToString()
                                    </div>
                                    @if (room.ExpiresAt.HasValue)
                                    {
                                        if (room.IsExpired)
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger fw-normal" style="width: fit-content;"><i class="fa-solid fa-clock"></i> Đã hết hạn</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success fw-normal" style="width: fit-content;"><i class="fa-solid fa-clock"></i> Còn @room.DaysLeft ngày</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning fw-normal" style="width: fit-content;">Chưa thanh toán</span>
                                    }
                                </div>
                            </td>
                            <td class="px-4">
                                <div class="d-flex gap-2 justify-content-center">
                                    <a class="btn btn-light border btn-sm rounded-circle d-flex justify-content-center align-items-center shadow-sm" style="width: 35px; height: 35px;" title="Xem chi tiết" asp-controller="Home" asp-action="Detail" asp-route-id="@room.Id"><i class="fa-solid fa-eye text-primary"></i></a>
                                    <a class="btn btn-primary btn-sm rounded-circle d-flex justify-content-center align-items-center shadow-sm" style="width: 35px; height: 35px;" title="Sửa bài viết" asp-action="Edit" asp-route-id="@room.Id"><i class="fa-solid fa-pen"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
