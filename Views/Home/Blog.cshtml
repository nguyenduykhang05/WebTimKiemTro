@{
    ViewData["Title"] = "Blog - Cẩm nang thuê phòng";
}

<!-- Hero Section -->
<div class="position-relative overflow-hidden rounded-4 mb-5" style="min-height: 400px;">
    <div class="position-absolute w-100 h-100" style="background: url('https://images.unsplash.com/photo-1554995207-c18c203602cb?auto=format&fit=crop&w=1200&q=80') center/cover;"></div>
    <div class="position-absolute w-100 h-100" style="background: linear-gradient(to right, rgba(15,23,42,0.95), rgba(15,23,42,0.4));"></div>
    
    <div class="container position-relative h-100 d-flex flex-column justify-content-center p-5" style="min-height: 400px; z-index: 2;">
        <span class="badge bg-primary px-3 py-2 mb-3" style="width: fit-content;">Mới Nhất</span>
        <h1 class="display-5 fw-bold text-white mb-3" style="max-width: 600px;">Bí quyết đàm phán giá thuê phòng trọ cực đỉnh năm 2026</h1>
        <p class="text-white opacity-75 fs-5 mb-4" style="max-width: 500px;">Làm thế nào để thuê được căn phòng ưng ý với giá hời nhất? Đừng bỏ qua những tips cực kỳ hữu ích này.</p>
        <div class="d-flex align-items-center">
            <img src="https://i.pravatar.cc/150?img=32" class="rounded-circle me-3 border border-2 border-primary" width="50" height="50">
            <div>
                <h6 class="mb-0 text-white fw-bold">Minh Trang</h6>
                <small class="text-white opacity-50">12 Tháng 6, 2026 • 5 phút đọc</small>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h3 class="fw-bold mb-1"><i class="fa-solid fa-fire text-danger me-2"></i>Cẩm nang HOT</h3>
            <p class="text-secondary small mb-0">Những bài viết được đọc nhiều nhất tuần qua.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow-sm">Tất cả</button>
            <button class="btn btn-light rounded-pill px-4 py-2 fw-bold border shadow-sm text-secondary hover-primary transition-all">Bất động sản</button>
            <button class="btn btn-light rounded-pill px-4 py-2 fw-bold border shadow-sm text-secondary hover-primary transition-all">Thị trường</button>
        </div>
    </div>

    <div class="row g-4">
        @if (ViewBag.Articles != null && ((IEnumerable<dynamic>)ViewBag.Articles).Any())
        {
            foreach (var article in (IEnumerable<dynamic>)ViewBag.Articles)
            {
                <div class="col-md-4">
                    <div class="card glass-panel border border-secondary border-opacity-10 h-100 overflow-hidden shadow-sm" style="border-radius: 1.2rem;">
                        <div style="height: 220px; overflow: hidden; position: relative;">
                            @{
                                var imgUrl = string.IsNullOrEmpty(article.ThumbnailUrl) ? "https://images.unsplash.com/photo-1560518883-ce09059eeffa?auto=format&fit=crop&w=600&q=80" : article.ThumbnailUrl;
                            }
                            <img src="@imgUrl" class="w-100 h-100 object-fit-cover hover-zoom" style="transition: transform 0.5s;" referrerpolicy="no-referrer">
                        </div>
                        <div class="card-body p-4 d-flex flex-column bg-white">
                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fw-bold mb-3" style="width: fit-content;">Bất động sản</span>
                            <h5 class="fw-bold mb-3 text-dark" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4;">@article.Title</h5>
                            <p class="text-secondary small mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">@article.Description</p>
                            <a href="@article.Link" target="_blank" rel="noopener noreferrer" class="mt-auto fw-bold text-decoration-none btn btn-light rounded-pill py-2 w-100 border text-primary shadow-sm hover-primary">Đọc bài viết <i class="fa-solid fa-arrow-up-right-from-square ms-1"></i></a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fa-regular fa-newspaper fs-1 text-secondary opacity-50 mb-3"></i>
                <h5 class="text-secondary">Đang tải dữ liệu bài viết mới nhất...</h5>
                <p class="text-muted">Vui lòng quay lại sau.</p>
            </div>
        }
    </div>
    
    @if (ViewBag.Articles != null && ((IEnumerable<dynamic>)ViewBag.Articles).Any())
    {
        <div class="text-center mt-5 mb-5">
            <button class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow-lg" style="transition: transform 0.2s;"><i class="fa-solid fa-rotate-right me-2"></i> Xem thêm bài viết</button>
        </div>
    }
</div>

<style>
    .hover-zoom:hover {
        transform: scale(1.1);
    }
</style>
