@model List<SmartRoomFinder.Models.DTOs.RecommendedRoomDto>

@{
    ViewData["Title"] = "Tin đăng tương tự";
    var originalRoomTitle = ViewData["OriginalRoomTitle"] as string;
    var originalRoomId = ViewData["OriginalRoomId"] as string;
}

@functions {
    public string GetTimeAgo(DateTime dt)
    {
        var span = DateTime.UtcNow - dt;
        if (span.Days > 365) return $"{span.Days / 365} năm trước";
        if (span.Days > 30) return $"{span.Days / 30} tháng trước";
        if (span.Days > 0) return $"{span.Days} ngày trước";
        if (span.Hours > 0) return $"{span.Hours} giờ trước";
        if (span.Minutes > 0) return $"{span.Minutes} phút trước";
        return "Vừa xong";
    }
}

<div class="container mb-5" style="max-width: 1400px; padding-top: 20px;">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-secondary">Trang chủ</a></li>
            @if (originalRoomTitle != null)
            {
                <li class="breadcrumb-item"><a href="/Home/Detail/@originalRoomId" class="text-decoration-none text-secondary text-truncate" style="max-width: 200px; display: inline-block; vertical-align: bottom;">@originalRoomTitle</a></li>
            }
            <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Tin đăng tương tự</li>
        </ol>
    </nav>

    <div class="glass-panel p-4 p-md-5 mb-4" style="background: #FFFFFF;">
        <h4 class="fw-bold mb-4 poppins-title">Tin đăng tương tự</h4>

        @if (Model != null && Model.Any())
        {
            <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-4">
                @foreach (var room in Model)
                {
                    <div class="col">
                        <div class="card similar-card border-light h-100 overflow-hidden text-decoration-none shadow-sm">
                            <div class="position-relative" style="height: 180px;">
                                <img src="@room.MainImageUrl" class="w-100 h-100 object-fit-cover" alt="@room.Title" onerror="this.src='/images/default_room.png'">
                                <div class="position-absolute bottom-0 start-0 m-2">
                                    <span class="badge bg-dark bg-opacity-75 text-white fw-normal"><i class="fa-solid fa-camera me-1"></i>4</span>
                                </div>
                                <div class="position-absolute top-0 end-0 m-2">
                                    <button class="btn btn-sm btn-light rounded-circle text-secondary p-1 px-2 opacity-75 shadow-none border-0"><i class="fa-regular fa-heart"></i></button>
                                </div>
                                <div class="position-absolute bottom-0 end-0 m-2">
                                    <span class="text-white small fw-bold" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.8);">@GetTimeAgo(room.PostedAt)</span>
                                </div>
                            </div>
                            <div class="card-body p-3 d-flex flex-column">
                                <h6 class="card-title mb-1 text-dark" style="font-size: 0.95rem; line-height: 1.4; height: 2.8em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;" title="@room.Title">
                                    @if(room.IsVerified) {
                                        <span class="badge bg-warning text-dark me-1" style="font-size: 0.7rem;"><i class="fa-solid fa-star me-1"></i>Đối tác</span>
                                    }
                                    <a href="/Home/Detail/@room.Id" class="text-dark text-decoration-none stretched-link">@room.Title</a>
                                </h6>
                                <div class="d-flex align-items-baseline mb-2 mt-1">
                                    <div class="text-danger fw-bold" style="font-size: 1.1rem;">@room.Price.ToString("N0") đ/tháng</div>
                                    @if(room.Area > 0) {
                                        <span class="ms-2 text-dark small">@room.Area m²</span>
                                    } else {
                                        <span class="ms-2 text-muted small fst-italic">Đang cập nhật</span>
                                    }
                                </div>
                                <div class="mt-auto small text-muted d-flex align-items-start" style="font-size: 0.8rem;">
                                    <i class="fa-solid fa-location-dot mt-1 me-1"></i>
                                    <span class="text-truncate" style="white-space: normal; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">@room.Address</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="w-100 text-center py-5">
                <i class="fa-solid fa-house-chimney-crack text-muted mb-3" style="font-size: 3rem;"></i>
                <h5 class="text-muted">Không tìm thấy phòng tương tự nào.</h5>
                <a href="/" class="btn btn-primary mt-3">Quay lại trang chủ</a>
            </div>
        }
    </div>
</div>

<style>
    .similar-card { transition: all 0.2s ease; border-radius: 8px; }
    .similar-card:hover { transform: translateY(-4px); box-shadow: 0 8px 20px rgba(0,0,0,0.1) !important; }
</style>
