@model IEnumerable<SmartRoomFinder.Models.RoomModel>

@{
    ViewData["Title"] = "Bản Đồ Tìm Phòng Trọ";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<div class="container-fluid px-4 mt-3 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="fw-bold mb-1 poppins-title"><i class="fa-solid fa-map-location-dot text-primary me-2"></i>Tìm Kiếm Phòng Trên Bản Đồ</h3>
            <p class="text-secondary small mb-0">Xem khoảng cách từ phòng trọ đến các trường đại học lớn trực quan trên bản đồ.</p>
        </div>
        <a class="btn btn-premium-secondary btn-sm" asp-action="Index"><i class="fa-solid fa-house me-1"></i> Trở về Trang chủ</a>
    </div>

    <!-- Chia đôi màn hình full height -->
    <div class="row g-4" style="min-height: calc(100vh - 180px);">
        <!-- Cột bên trái: Danh sách phòng trọ (cuộn độc lập) -->
        <div class="col-lg-5" style="max-height: calc(100vh - 180px); overflow-y: auto; padding-right: 15px;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-secondary small fw-bold">Hiện có @Model.Count() phòng trong khu vực</span>
                <span class="badge bg-primary bg-opacity-10 text-primary">Map View</span>
            </div>

            <div class="row g-3">
                @foreach (var room in Model)
                {
                    <div class="col-12">
                        <div class="card glass-panel border border-secondary border-opacity-10 p-3 h-100 room-card-premium" style="background: #FFFFFF;">
                            <div class="row g-3">
                                <div class="col-4">
                                    <img src="@room.MainImageUrl" class="rounded-3 w-100 h-100 object-fit-cover" style="min-height: 110px;" alt="Room" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=150&q=80'">
                                </div>
                                <div class="col-8 d-flex flex-column justify-content-between">
                                    <div>
                                        <div class="d-flex justify-content-between align-items-start">
                                            <h6 class="fw-bold mb-1 text-truncate" style="max-width: 180px;">@room.Title</h6>
                                            <span class="rating-star-premium small" style="font-size: 0.75rem;"><i class="fa-solid fa-star me-1"></i>@room.Rating.ToString("0.0")</span>
                                        </div>
                                        <p class="small text-secondary mb-2" style="font-size: 0.75rem;"><i class="fa-solid fa-location-dot text-danger me-1"></i> @room.Location</p>
                                        <span class="badge bg-light text-primary border border-primary border-opacity-10 py-1 px-2" style="font-size: 0.65rem;">@room.Type.ToString()</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <span class="price-premium small" style="font-size: 1.15rem;">@room.Price.ToString("#,##0") <span class="small text-secondary fw-normal" style="font-size: 0.75rem;">đ/th</span></span>
                                        <a class="btn btn-premium btn-sm px-3 py-1" style="font-size: 0.75rem; border-radius: 15px;" asp-action="Detail" asp-route-id="@room.Id">Chi tiết</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Cột bên phải: Bản đồ lớn (mockup) -->
        <div class="col-lg-7">
            <div class="map-sticky-panel d-flex flex-column" style="height: calc(100vh - 110px); top: 75px; position: sticky;">
                <div class="map-header mb-2 border border-secondary border-opacity-10 shadow-sm bg-white" style="border-radius: 50px; padding: 4px 6px 4px 20px;">
                    <div class="d-flex flex-row flex-wrap align-items-center justify-content-between gap-2">
                        <h6 class="fw-bold mb-0 poppins-title d-flex align-items-center text-nowrap" style="font-size: 0.95rem;"><i class="fa-solid fa-earth-americas text-primary me-2 fs-6"></i>Tìm kiếm bán kính</h6>
                        
                        <div class="d-flex flex-row align-items-center ms-auto">
                            
                            <div class="d-flex flex-column justify-content-center" style="min-width: 150px;">
                                <label class="text-uppercase fw-bold text-dark mb-0 d-flex align-items-center gap-1" style="font-size: 0.55rem; letter-spacing: 0.5px;"><i class="fa-solid fa-location-dot text-danger"></i> MỐC VỊ TRÍ</label>
                                <select id="landmarkSelect" class="form-select form-select-sm border-0 bg-transparent px-0 fw-bold shadow-none text-dark py-0" style="font-size: 0.85rem; cursor: pointer; min-height: auto;">
                                    <option value="">-- Chọn mốc vị trí --</option>
                                </select>
                            </div>
                            
                            <div class="border-start border-secondary border-opacity-25 mx-2" style="height: 25px;"></div>
                            
                            <div class="d-flex flex-column justify-content-center" style="min-width: 120px;">
                                <label class="text-uppercase fw-bold text-dark mb-0 d-flex align-items-center gap-1" style="font-size: 0.55rem; letter-spacing: 0.5px;"><i class="fa-solid fa-compass text-primary"></i> BÁN KÍNH</label>
                                <select id="radiusSelect" class="form-select form-select-sm border-0 bg-transparent px-0 fw-bold shadow-none text-dark py-0" style="font-size: 0.85rem; cursor: pointer; min-height: auto;">
                                    <option value="1">Trong vòng 1 km</option>
                                    <option value="3" selected>Trong vòng 3 km</option>
                                    <option value="5">Trong vòng 5 km</option>
                                    <option value="10">Trong vòng 10 km</option>
                                </select>
                            </div>
                            
                            <div class="d-flex gap-1 ms-2 pe-1">
                                <button id="btnSearchRadius" class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 34px; height: 34px; transition: all 0.2s; padding: 0;" title="Tìm kiếm">
                                    <i class="fa-solid fa-magnifying-glass" style="font-size: 0.85rem;"></i>
                                </button>
                                <button id="btnResetMap" class="btn btn-light border border-secondary border-opacity-25 rounded-circle d-flex align-items-center justify-content-center" style="width: 34px; height: 34px; transition: all 0.2s; background-color: #f8f9fa; padding: 0;" title="Khôi phục mặc định">
                                    <i class="fa-solid fa-rotate-right text-secondary" style="font-size: 0.85rem;"></i>
                                </button>
                            </div>
                            
                        </div>
                    </div>
                </div>

                <div class="map-body-mock bg-light border border-secondary border-opacity-25 flex-grow-1" style="border-radius: 1rem; overflow: hidden; position: relative; min-height: 300px;">
                    <div id="real-map" style="width: 100%; height: 100%; position: absolute; top: 0; left: 0;"></div>
                </div>

                <!-- Bottom Mini Card (Dynamic updates via Javascript) -->
                <div class="p-3 bg-white border-top border-light animate-fade-in" id="miniMapCard">
                    <div class="d-flex align-items-center">
                        <img id="miniCardImg" src="https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=150&q=80" 
                             class="rounded me-3" style="width: 70px; height: 70px; object-fit: cover;" alt="Mini">
                        <div class="flex-grow-1 min-width-0">
                            <h6 class="fw-bold mb-1 text-truncate" id="miniCardTitle">Phòng trọ gác gỗ đơn giản Quận 7</h6>
                            <span class="small text-secondary d-block mb-1"><i class="fa-solid fa-location-dot text-danger me-1"></i> Xung quanh khu vực Đại Học</span>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-primary fw-bold small" id="miniCardPrice">2.500.000đ / tháng</span>
                                <span class="text-warning small" style="font-size: 0.7rem;"><i class="fa-solid fa-star"></i> <span id="miniCardRating">4.2</span></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        // Init map centered at HCMC (default)
        var map = L.map('real-map').setView([10.800, 106.700], 12);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap contributors &copy; CARTO'
        }).addTo(map);

        // Add custom markers from model
        var rooms = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(r => new { r.Id, r.Title, r.Price, r.Rating, r.MainImageUrl, r.Latitude, r.Longitude })));
        // Tải danh sách Landmarks và hiển thị lên bản đồ
        var landmarkMarkers = [];
        
        function showMiniCard(title, price, rating, img, id) {
            document.getElementById('miniCardTitle').innerText = title;
            document.getElementById('miniCardPrice').innerText = price + ' / tháng';
            document.getElementById('miniCardRating').innerText = rating || '5.0';
            document.getElementById('miniCardImg').src = img;
            
            // Cập nhật link chi tiết
            var card = document.getElementById('miniMapCard');
            card.onclick = function() { window.location.href = '/Home/Detail/' + id; };
            card.style.cursor = 'pointer';

            card.style.animation = 'none';
            card.offsetHeight; // trigger reflow
            card.style.animation = 'fadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards';
        }

        // ==========================
        // Radius Search Logic (AJAX)
        // ==========================
        var currentMarkers = [];
        var radiusCircle = null;
        var landmarkMarker = null;

        function clearMap() {
            currentMarkers.forEach(m => map.removeLayer(m));
            currentMarkers = [];
            if (radiusCircle) map.removeLayer(radiusCircle);
            if (landmarkMarker) map.removeLayer(landmarkMarker);
        }

        fetch('/api/LandmarkApi')
            .then(res => res.json())
            .then(data => {
                if(data.success && data.data) {
                    var select = document.getElementById('landmarkSelect');
                    data.data.forEach(l => {
                        // Thêm vào dropdown
                        var opt = document.createElement('option');
                        opt.value = l.latitude + ',' + l.longitude;
                        opt.text = l.name;
                        select.appendChild(opt);

                        // Thêm marker lên bản đồ
                        var shortName = l.name.replace("Đại học ", "").replace("Trường ", "");
                        var icon = L.divIcon({ 
                            className: 'custom-div-icon', 
                            html: "<div style='background-color:#0d6efd; color:white; padding:5px 10px; border-radius:15px; font-weight:bold; font-size:11px; white-space:nowrap; box-shadow:0 2px 5px rgba(0,0,0,0.3);'><i class='fa-solid fa-graduation-cap me-1'></i>" + shortName + "</div>", 
                            iconSize: null, // Let it size automatically based on content
                            iconAnchor: [0, 15] // We'll adjust anchor approximately
                        });
                        var lMarker = L.marker([l.latitude, l.longitude], {icon: icon}).addTo(map).bindPopup(l.name);
                        landmarkMarkers.push(lMarker);
                    });
                }
            });

        document.getElementById('btnSearchRadius').addEventListener('click', function() {
            var val = document.getElementById('landmarkSelect').value;
            var radius = parseFloat(document.getElementById('radiusSelect').value);
            if (!val) {
                alert('Vui lòng chọn mốc vị trí!'); return;
            }
            var parts = val.split(',');
            var lat = parseFloat(parts[0]);
            var lng = parseFloat(parts[1]);

            clearMap();

            // Vẽ tâm
            var icon = L.divIcon({ className: 'custom-div-icon', html: "<div style='background-color:#0d6efd; color:white; padding:5px 10px; border-radius:15px; font-weight:bold; font-size:12px; box-shadow:0 2px 5px rgba(0,0,0,0.3);'><i class='fa-solid fa-location-crosshairs me-1'></i>Tâm</div>", iconSize: [80, 30], iconAnchor: [40, 15] });
            landmarkMarker = L.marker([lat, lng], {icon: icon}).addTo(map);

            // Vẽ vòng tròn bán kính
            radiusCircle = L.circle([lat, lng], {
                color: '#0d6efd',
                fillColor: '#0d6efd',
                fillOpacity: 0.1,
                radius: radius * 1000
            }).addTo(map);

            map.fitBounds(radiusCircle.getBounds());

            // Gọi API
            fetch(`/api/RoomApi/radius?lat=${lat}&lng=${lng}&radiusKm=${radius}`)
                .then(res => res.json())
                .then(res => {
                    if (res.success && res.data) {
                        res.data.forEach(function(room) {
                            var priceStr = (room.price / 1000000).toFixed(1) + 'tr';
                            var roomIcon = L.divIcon({
                                className: 'custom-div-icon',
                                html: "<div style='background-color:#ef4444; color:white; padding:4px 8px; border-radius:12px; font-weight:bold; font-size:11px; box-shadow:0 2px 5px rgba(0,0,0,0.3); cursor:pointer;'>" + priceStr + "</div>",
                                iconSize: [40, 24],
                                iconAnchor: [20, 12]
                            });
                            
                            var marker = L.marker([room.latitude, room.longitude], {icon: roomIcon}).addTo(map);
                            currentMarkers.push(marker);
                            
                            marker.on('click', function() {
                                showMiniCard(room.title, new Intl.NumberFormat('vi-VN').format(room.price) + 'đ', '5.0', room.imageUrl, room.id);
                            });
                        });
                        alert(`Tìm thấy ${res.count} phòng trong bán kính ${radius}km!`);
                    }
                });
        });

        document.getElementById('btnResetMap').addEventListener('click', function() {
            window.location.reload();
        });

        // Initialize default markers from SSR
        rooms.forEach(function(room) {
            if(room.Latitude && room.Longitude) {
                var priceStr = (room.Price / 1000000).toFixed(1) + 'tr';
                var roomIcon = L.divIcon({
                    className: 'custom-div-icon',
                    html: "<div style='background-color:#ef4444; color:white; padding:4px 8px; border-radius:12px; font-weight:bold; font-size:11px; box-shadow:0 2px 5px rgba(0,0,0,0.3); cursor:pointer;'>" + priceStr + "</div>",
                    iconSize: [40, 24],
                    iconAnchor: [20, 12]
                });
                
                var marker = L.marker([room.Latitude, room.Longitude], {icon: roomIcon}).addTo(map);
                currentMarkers.push(marker);
                
                marker.on('click', function() {
                    showMiniCard(room.Title, new Intl.NumberFormat('vi-VN').format(room.Price) + 'đ', room.Rating.toFixed(1), room.MainImageUrl, room.Id);
                });
            }
        });
    </script>
}
